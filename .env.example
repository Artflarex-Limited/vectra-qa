### LLM PROVIDERS ###
# REQUIRED: Choose your primary LLM provider for the Orchestrator agent.
# The Orchestrator uses this to plan tests, spawn agents, and compile reports.
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxx

# OPTIONAL: Anthropic API key for the UI Explorer agent (frontend testing).
# This agent benefits from Claude's strong reasoning for DOM analysis.
# Obtain from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxx

# OPTIONAL: Google API key for the Data Validator agent (backend testing).
# Gemini Pro is excellent at structured data analysis and schema validation.
# Obtain from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyxxxxxxxxx

# OPTIONAL: Local LLM endpoint for privacy-sensitive testing.
# Use this if you run Llama, Mistral, or other models locally via Ollama or LM Studio.
# Format: http://localhost:11434/v1 (Ollama) or http://localhost:1234/v1 (LM Studio)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1:70b

# OPTIONAL: MiniMax API for high-quality Chinese/English generation and analysis.
# MiniMax provides strong performance for structured output and long-context tasks.
# Uses OpenAI-compatible API format.
# Obtain from: https://www.minimaxi.com/
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=minimax-m2.7

# OPTIONAL: Kimi (Moonshot AI) for ultra-long context analysis.
# Kimi specializes in processing massive contexts (up to 2M tokens).
# Ideal for Data Validator analyzing large API payloads and network logs.
# Uses OpenAI-compatible API format.
# Obtain from: https://platform.moonshot.cn/
KIMI_API_KEY=your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# REQUIRED: Default model selection for each agent role.
# Format: provider/model-name
# Supported providers: openai, anthropic, google, local, minimax, kimi
# Examples:
#   openai/gpt-4o
#   anthropic/claude-3-5-sonnet-20241022
#   minimax/minimax-text-01
#   kimi/kimi-k2
ORCHESTRATOR_MODEL=openai/gpt-4o
UI_EXPLORER_MODEL=anthropic/claude-3-5-sonnet-20241022
DATA_VALIDATOR_MODEL=openai/gpt-4o

### RAG & VECTOR DATABASE ###
# REQUIRED: Vector database connection for the RAG pipeline.
# The Orchestrator retrieves user stories and requirements from this store.
# Supported: chroma, pinecone, weaviate, qdrant
VECTOR_DB_PROVIDER=chroma

# REQUIRED: ChromaDB specific settings (if using Chroma).
# For local development, this is a directory path. For cloud, use the full URL.
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=test_requirements

# OPTIONAL: Pinecone specific settings (if using Pinecone).
# Obtain from: https://app.pinecone.io/
PINECONE_API_KEY=pc-xxxxxxxxx
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=vectra-qa-requirements

# OPTIONAL: Embedding model for vectorizing test documents.
# Defaults to OpenAI's text-embedding-3-small if not specified.
EMBEDDING_MODEL=text-embedding-3-small

### OBSIDIAN MEMORY ###
# REQUIRED: Absolute path to your Obsidian Vault directory.
# Agents read/write Markdown files here. This directory must exist and be writable.
# Example: /home/user/Documents/Obsidian/Vaults/VectraQA
# Windows: C:\Users\user\Documents\Obsidian\Vaults\VectraQA
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# OPTIONAL: Template directory for agent memory nodes.
# If not set, defaults to {OBSIDIAN_VAULT_PATH}/Templates
AGENT_TEMPLATE_DIR=/path/to/your/obsidian/vault/Templates

# OPTIONAL: Global memory nodes directory.
# Stores Test_Run_Master.md, UI_State_Log.md, etc.
# Defaults to {OBSIDIAN_VAULT_PATH}/Global
GLOBAL_NODES_DIR=/path/to/your/obsidian/vault/Global

### BROWSER AUTOMATION ###
# REQUIRED: Playwright browser configuration.
# Options: chromium, firefox, webkit
PLAYWRIGHT_BROWSER=chromium

# OPTIONAL: Run browsers in headless mode?
# Set to false to watch the browser during tests (useful for debugging).
HEADLESS=true

# OPTIONAL: Slow down Playwright operations by specified milliseconds.
# Useful for observing interactions during development.
PLAYWRIGHT_SLOW_MO=0

# OPTIONAL: Browser viewport size.
PLAYWRIGHT_VIEWPORT_WIDTH=1920
PLAYWRIGHT_VIEWPORT_HEIGHT=1080

### SERVER CONFIG ###
# REQUIRED: MCP Server port and transport.
# The MCP Tool Server exposes agent tools via stdio or SSE.
MCP_SERVER_PORT=8080
MCP_TRANSPORT=sse

# REQUIRED: Command Center dashboard backend.
# FastAPI server that serves the HTMX UI and streams SSE updates.
COMMAND_CENTER_PORT=3000
COMMAND_CENTER_HOST=0.0.0.0

# OPTIONAL: CORS origins for the Command Center.
# Comma-separated list of allowed origins. Use * for development.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OPTIONAL: Log level for all services.
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

### SECURITY & AUTH ###
# OPTIONAL: API key for authenticating with the MCP server.
# If set, all tool calls must include this key in the Authorization header.
MCP_API_KEY=your-secure-mcp-api-key-here

# OPTIONAL: Secret key for the Command Center session management.
# Generate with: openssl rand -hex 32
COMMAND_CENTER_SECRET_KEY=your-secret-key-here

# WARNING: NEVER commit real API keys or secrets to version control.
# Always use this .env.example as a template and create your own .env file.
CHATBOT_MODEL=minimax/minimax-m2.7
CHATBOT_MAX_HISTORY=50
CHATBOT_ENABLE_STREAMING=true